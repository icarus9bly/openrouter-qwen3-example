# OpenRouter Configuration
# OPTION 1: Set your OpenRouter API key directly (simplest option)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# OPTION 2: Use Infisical for secrets management
# Leave OPENROUTER_API_KEY empty above and configure Infisical credentials below
# These can also be stored in your system keyring if not set here

# Infisical client credentials (from Universal Auth setup)
INFISICAL_CLIENT_ID=your-client-id-here
INFISICAL_CLIENT_SECRET=your-client-secret-here
INFISICAL_PROJECT_ID=your-project-id-here

# Note: If these variables are not set in .env, the app will look for them in system keyring
# with the service name "infisical" and matching usernames:
# - keyring.get_password("infisical", "client_id")
# - keyring.get_password("infisical", "client_secret")
# - keyring.get_password("infisical", "project_id")
